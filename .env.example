# Environment: dev (local only) or production (upload to S3)
ENVIRONMENT=dev

# Log level: DEBUG, INFO, WARNING, ERROR (optional, default: INFO)
LOG_LEVEL=INFO

# S3-compatible storage (required for production only)
# Example: Cloudflare R2, AWS S3, MinIO
S3_API=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
